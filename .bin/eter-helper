#!/usr/bin/env bash
set -euo pipefail

unset LDFLAGS 
unset CPPFLAGS

LLVM_PREFIX_PATH=${LLVM_PREFIX_PATH:-/opt/homebrew/opt/llvm@22}
export PATH="${LLVM_PREFIX_PATH}/bin:$PATH" # export to ensure subprocesses can use the same LLVM tools
LIT_COMMAND=lit
BUILD_DIR=./build
CLANG_FORMAT_COMMIT=HEAD
CLANG_TIDY_COMMIT=HEAD
# LLVM_DIR=${LLVM_DIR:-${LLVM_PREFIX_PATH}/lib/cmake/llvm}
# MLIR_DIR=${MLIR_DIR:-${LLVM_PREFIX_PATH}/lib/cmake/mlir}

print_usage() {
    echo "Usage: eter-helper <command> [arguments]"
    echo ""
    echo "Commands:"
    echo "  config [BUILD_TYPE]                  Configure the Eter project with CMake."
    echo "  build                                Build the project using ninja."
    echo "  rebuild                              Re-configure and build the project from scratch."
    echo "  check-eter                           Run the Eter-specific test suite."
    echo "  doc-doxygen                          Generate documentation using Doxygen."
    echo "  test <folder|file>                   Run the lit test suite."
    echo "  check-clang-format [COMMIT]          Run clang-format on staged changed files compared to a git commit."
    echo "  clang-format [CLANG_FORMAT_COMMIT]   Format staged changed files compared to a git commit using clang-format."
    echo "  clang-tidy [CLANG_TIDY_COMMIT]       Run clang-tidy on staged changed files compared to a git commit."
    echo "  create-clangd                        Create a .clangd configuration file for the project."
    echo "  clean                                Clean the build directory."
    echo "  help                                 Show this help message."
    echo ""
    echo "Environment:"
    echo "  LLVM_PREFIX_PATH     Path to LLVM installation directory (default: /opt/homebrew/opt/llvm@22)"
    echo "  LIT_COMMAND          Command to run lit tests (default: lit)"
    echo "  BUILD_DIR            Directory for CMake build files (default: ./build)"
    echo ""
    echo "Options:"
    echo "  BUILD_TYPE           Build type for configuration (e.g., Debug, Release). Default is Debug."
    echo "  CLANG_FORMAT_COMMIT  Git commit to compare against for clang-format (default: HEAD)."
    echo "  CLANG_TIDY_COMMIT    Git commit to compare against for clang-tidy (default: HEAD)."
    echo ""
    echo "Location:"
    echo "  eter-helper is located at: $(realpath $0)"
    # FUTURE ADDITIONS:
    # echo "  update-test-checks <file>             Update the FileCheck patterns in the given test file."
}


# Show help message if no arguments are provided
if [ $# -eq 0 ]; then
    print_usage
    exit 0
fi

COMMAND=$1
shift # Remove the command from the arguments list

case $COMMAND in
    config)
        BUILD_TYPE=${1:-Debug}
        echo "[eter-helper] Configuring Eter project"
        rm -rf ${BUILD_DIR}
        mkdir -p ${BUILD_DIR}
        cmake -G Ninja -S . -B ${BUILD_DIR} \
            -DCMAKE_BUILD_TYPE=${BUILD_TYPE} \
            -DCMAKE_PREFIX_PATH=${LLVM_PREFIX_PATH} \
            -DCMAKE_C_COMPILER=${LLVM_PREFIX_PATH}/bin/clang \
            -DCMAKE_CXX_COMPILER=${LLVM_PREFIX_PATH}/bin/clang++ \
            -DLLVM_ENABLE_ASSERTIONS=ON
        ;;

    build)
        echo "[eter-helper] Building project"
        cmake --build ${BUILD_DIR} # ninja -C ${BUILD_DIR}
        ;;

    rebuild)
        echo "[eter-helper] Rebuilding project from scratch"
        rm -rf ${BUILD_DIR}
        $0 config
        $0 build
        ;;

    check-eter)
        echo "[eter-helper] Running Eter-specific tests"
        cmake --build ${BUILD_DIR} --target check-eter
        ;;
    
    doc-doxygen)
        echo "[eter-helper] Generating documentation using Doxygen"
        cmake --build ${BUILD_DIR} --target doc-doxygen
        ;;

    test)
        if [ -z "${1:-}" ]; then
            echo "[eter-helper] Error: Missing path argument for 'test' command."
            print_usage
            exit 1
        fi
        echo "[eter-helper] Running lit tests"
        INPUT_FOLDER=$1
        ${LIT_COMMAND} -a -s -v "${INPUT_FOLDER}"
        ;;
    
    check-clang-format)
        CLANG_FORMAT_COMMIT=${1:-$CLANG_FORMAT_COMMIT}
        echo "[eter-helper] Checking clang-format against git commit ${CLANG_FORMAT_COMMIT}"
        # git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(c|cc|cpp|cxx|h|hh|hpp|hxx)$' | xargs -r clang-format --dry-run --Werror
        # clang-format --dry-run --Werror $(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(c|cc|cpp|cxx|h|hh|hpp|hxx)$')
        git clang-format --diff ${CLANG_FORMAT_COMMIT}
        ;;
    
    clang-format)
        CLANG_FORMAT_COMMIT=${1:-$CLANG_FORMAT_COMMIT}
        echo "[eter-helper] Running clang-format against git commit ${CLANG_FORMAT_COMMIT}"
        git clang-format ${CLANG_FORMAT_COMMIT}
        ;;

    clang-tidy)
        CLANG_TIDY_COMMIT=${1:-$CLANG_TIDY_COMMIT}
        echo "[eter-helper] Running clang-tidy against git commit ${CLANG_TIDY_COMMIT}"
        # Get the list of changed files
        CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR ${CLANG_TIDY_COMMIT} | grep -E '\.(c|cc|cpp|cxx)$' || true)
        if [ -z "$CHANGED_FILES" ]; then
            echo "[eter-helper] No C/C++ files changed compared to ${CLANG_TIDY_COMMIT}. Skipping clang-tidy."
            exit 0
        fi
        echo "[eter-helper] Running clang-tidy on the following files:"
        echo "$CHANGED_FILES"
        # Run clang-tidy on the changed files
        clang-tidy $CHANGED_FILES -p ${BUILD_DIR} --header-filter='.*'
        ;;  

    create-clangd)
        echo "[eter-helper] Creating .clangd configuration file"
        cat > .clangd <<EOL
CompileFlags:
  CompilationDatabase: ${BUILD_DIR}/
EOL
        echo "[eter-helper] .clangd file created with compilation database path: ${BUILD_DIR}/"
        ;;

    clean)
        echo "[eter-helper] Cleaning build directory"
        rm -rf ${BUILD_DIR}
        ;;

    help|*)
        print_usage
        ;;

    # update-test-checks)
    #     if [ -z "${1:-}" ]; then
    #         echo "[eter-helper] Error: Missing input file for 'update-test-checks' command."
    #         print_usage
    #         exit 1
    #     fi
    #     INPUT_FILE=$1
    #     echo "[eter-helper] Updating FileCheck patterns in ${INPUT_FILE}"
    #     python3 mlir/utils/update_test_checks.py \
    #         --opt-binary=${BUILD_DIR}/bin/mlir-opt \
    #         ${INPUT_FILE}
    #     ;;
esac

echo "[eter-helper] Done."

