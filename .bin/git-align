#!/bin/bash

# Exit immediately if a command exits with a non-zero status
set -e

echo "Starting fork synchronization..."

# 1. Verify we are inside a Git repository
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: Not a git repository. Please run this inside your project folder."
    exit 1
fi

# 2. Determine the default branch (main or master)
if git show-ref --verify --quiet refs/heads/main; then
    DEFAULT_BRANCH="main"
elif git show-ref --verify --quiet refs/heads/master; then
    DEFAULT_BRANCH="master"
else
    echo "Error: Neither 'main' nor 'master' branch found locally."
    exit 1
fi

# 3. Check for the 'upstream' remote
if ! git remote -v | grep -q "^upstream"; then
    echo "'upstream' remote not found."
    read -p "Enter the original repository URL to set as upstream: " UPSTREAM_URL
    if [ -n "$UPSTREAM_URL" ]; then
        git remote add upstream "$UPSTREAM_URL"
        echo "Upstream remote added successfully."
    else
        echo "Error: Upstream URL is required to sync."
        exit 1
    fi
fi

# 4. Fetch the latest changes
echo "Fetching latest changes from upstream..."
git fetch upstream

# 5. Sync the default branch
echo "Syncing local '$DEFAULT_BRANCH' with upstream/$DEFAULT_BRANCH..."
git checkout "$DEFAULT_BRANCH"
git rebase "upstream/$DEFAULT_BRANCH"

echo "Pushing updated '$DEFAULT_BRANCH' to your fork (origin)..."
git push origin "$DEFAULT_BRANCH" --force-with-lease

# 6. Sync additional feature branches (if provided)
if [ $# -gt 0 ]; then
    echo "Updating additional feature branches: $@"
    for BRANCH in "$@"; do
        echo "----------------------------------------"
        echo "Processing branch: $BRANCH"

        # Check if the branch exists locally
        if git show-ref --verify --quiet refs/heads/"$BRANCH"; then
            git checkout "$BRANCH"
            echo "   Rebasing '$BRANCH' onto updated '$DEFAULT_BRANCH'..."
            git rebase "$DEFAULT_BRANCH"

            echo "   Pushing updated '$BRANCH' to origin..."
            # Using --force-with-lease because rebase rewrites git history safely
            git push origin "$BRANCH" --force-with-lease
        else
            echo "Branch '$BRANCH' does not exist locally. Skipping."
        fi
    done
fi

echo "----------------------------------------"
# Return to the default branch at the end
git checkout "$DEFAULT_BRANCH"
echo "Fork successfully synchronized!"

